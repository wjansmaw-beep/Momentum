{
  "expo": {
    "name": "Momentum",
    "slug": "momentum",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Momentum gebruikt je globale locatie alleen wanneer je zelf om iets in de buurt vraagt.",
          "isIosBackgroundLocationEnabled": false,
          "isAndroidBackgroundLocationEnabled": false,
          "isAndroidForegroundServiceEnabled": false
        }
      ]
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.momentum.prototype"
    },
    "android": {
      "package": "com.momentum.prototype",
      "blockedPermissions": [
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    }
  }
}
