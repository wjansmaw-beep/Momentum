# Momentum Generator Service environment names (ADR-056).
# Server-only. Never commit values, never prefix with EXPO_PUBLIC_.
# Copy to your own uncommitted env file or export in your shell.

# Provider selection: fixture | openai | anthropic | moonshot
# Missing or unknown falls back to fixture; keys are never guessed.
MOMENTUM_GENERATOR_PROVIDER=

# OpenAI (Responses API, strict structured outputs)
OPENAI_API_KEY=
OPENAI_MODEL=

# Anthropic (Messages API, tool-use structured output)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Moonshot / Kimi (OpenAI-compatible chat completions, JSON mode)
MOONSHOT_API_KEY=
MOONSHOT_MODEL=
MOONSHOT_BASE_URL=

# Operational guard rails
MOMENTUM_GENERATOR_PORT=
MOMENTUM_GENERATOR_HOST=
MOMENTUM_ALLOWED_ORIGINS=
MOMENTUM_GENERATOR_TIMEOUT_MS=
MOMENTUM_GENERATOR_MAX_OUTPUT_TOKENS=
MOMENTUM_GENERATOR_DAILY_CALL_LIMIT=
MOMENTUM_GENERATOR_BUDGET_EUR=
MOMENTUM_GENERATOR_USD_PER_EUR=

# Native client access (ADR-063) — app-side constant, not an env var.
# Browsers are governed by MOMENTUM_ALLOWED_ORIGINS. React Native sends no
# Origin header, so requests without an Origin are admitted only when they
# carry this fixed header with this exact value:
#   X-Momentum-Client: native
# The header is explicit client identification, not a secret and not
# authentication. Bind to 0.0.0.0 only on your own home network; the service
# must never be exposed publicly without real authentication (Generator
# Service Runbook, production prerequisites).
